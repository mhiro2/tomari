{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tomari",
  "version": "0.1.0",
  "identifier": "io.github.mhiro2.tomari",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Tomari",
        "width": 440,
        "height": 640,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "visible": false,
        "decorations": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "26.0"
    },
    "category": "Productivity",
    "shortDescription": "Keyboard customization and window management for macOS.",
    "longDescription": "Tomari redefines your modifier keys with taps and hotkeys, and snaps windows around your screen — all from a single menu-bar icon."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["tomari"]
      }
    },
    "updater": {
      "endpoints": ["https://github.com/mhiro2/tomari/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3QTdERjY1M0NEQUNGRUUKUldUdXo5bzhaZCtuMS84a0tKeVo1Q2FhVnVRQ1dILzFqbi9BNEIyTmd6MEVvNDZuVEwyTWErYjUK"
    }
  }
}
